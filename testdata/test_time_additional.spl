let ok = true;

if (iso_to_unix("1970-01-01T00:00:00Z") != 0) { ok = false; }
if (iso_to_unix_ms("1970-01-01T00:00:00Z") != 0) { ok = false; }
if (format_time(0, "YYYY-MM-DD HH:mm:ss") != "1970-01-01 00:00:00") { ok = false; }
if (parse_time("1970-01-01 00:00:00", "YYYY-MM-DD HH:mm:ss") != 0) { ok = false; }
if (date_with_format(2026, 2, 23, "YYYY-MM-DD") != "2026-02-23") { ok = false; }
if (time_add(0, 1, "day") != 86400) { ok = false; }
if (time_sub(86400, 1, "day") != 0) { ok = false; }
if (time_diff(86400, 0, "day") != 1) { ok = false; }
if (start_of_day(86399) != 0) { ok = false; }
if (end_of_day(1) != 86399) { ok = false; }
if (len(now_format("YYYY-MM-DD")) != 10) { ok = false; }
if (now() <= 0) { ok = false; }
if (time_ms() <= 0) { ok = false; }
if (len(now_iso()) < 20) { ok = false; }

ok;
