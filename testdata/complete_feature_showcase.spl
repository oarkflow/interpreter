// -----------------------------------------------------------------------------
// 43) Pattern matching (match expression — all 11 pattern types)
// -----------------------------------------------------------------------------
print "=== Pattern matching ===";

// 43a) Literal patterns
let r1 = match (42) {
    case 1 => "one"
    case 42 => "forty-two"
    case 100 => "hundred"
};
print sprintf("literal: %s", r1);

// 43b) Wildcard pattern
let r2 = match (999) {
    case 1 => "one"
    case _ => "other"
};
print sprintf("wildcard: %s", r2);

// 43c) Variable binding
let r3 = match (42) {
    case n => "got " + n
};
print sprintf("binding: %s", r3);

// 43d) Type patterns
let testType = function(val) {
    return match (val) {
        case n: integer => "integer: " + n
        case s: string  => "string: " + s
        case b: boolean => "boolean: " + b
        case a: array   => "array of length " + len(a)
        case h: hash    => "it's a hash"
        case _: float   => "a float"
        case _          => "unknown"
    };
};
print testType(42);
print testType("hi");
print testType(true);
print testType([1,2,3]);
print testType({"a": 1});
print testType(3.14);

// 43e) Array destructuring
let r4 = match ([1, 2, 3]) {
    case [a, b, c] => a + b + c
};
print sprintf("array destructure: %d", r4);

let r5 = match ([10, 20, 30, 40, 50]) {
    case [head, ...tail] => "head=" + head + " tail_len=" + len(tail)
};
print sprintf("rest pattern: %s", r5);

// 43f) Object destructuring
let personMatch = {"name": "Alice", "age": 30, "city": "NYC"};
let r6 = match (personMatch) {
    case {name, age} => name + " is " + age
};
print sprintf("object destructure: %s", r6);

let r7 = match (personMatch) {
    case {name: n, age: a} => n + " age " + a
};
print sprintf("object rename: %s", r7);

// 43g) Guard clauses
let classify = function(n) {
    return match (n) {
        case x if x > 0 => "positive"
        case x if x < 0 => "negative"
        case _ => "zero"
    };
};
print sprintf("guard(5): %s", classify(5));
print sprintf("guard(-3): %s", classify(-3));
print sprintf("guard(0): %s", classify(0));

// 43h) OR patterns
let r8 = match (2) {
    case 1 | 2 | 3 => "small"
    case 4 | 5 | 6 => "medium"
    case _ => "large"
};
print sprintf("or pattern: %s", r8);

// 43i) Range patterns (inside match)
let grade = function(score) {
    return match (score) {
        case 90..100 => "A"
        case 80..89  => "B"
        case 70..79  => "C"
        case 60..69  => "D"
        case _       => "F"
    };
};
print sprintf("grade(95): %s", grade(95));
print sprintf("grade(42): %s", grade(42));

// 43j) Comparison patterns
let r9 = match (15) {
    case > 100 => "huge"
    case > 10  => "big"
    case > 0   => "small"
    case _     => "non-positive"
};
print sprintf("comparison: %s", r9);

// 43k) Extractor patterns (Some/None, Regex)
let r10 = match ("Alice") {
    case Some(s: string) => "Hello, " + s
    case None => "no name"
};
print sprintf("extractor: %s", r10);

let r11 = match (null) {
    case Some(x) => "got " + x
    case None => "nothing"
};
print sprintf("none: %s", r11);

let r12 = match ("12345") {
    case Regex("^[0-9]+$") => "numeric"
    case Regex("^[a-z]+$") => "alpha"
    case _ => "mixed"
};
print sprintf("regex: %s", r12);

// 43l) Nested patterns
let nestedData = {"users": [{"name": "Bob"}, {"name": "Eve"}]};
let r13 = match (nestedData) {
    case {users: [first, ...rest]} => first.name
};
print sprintf("nested: %s", r13);

// 43m) Match as expression (assigned to variable)
let status2 = "active";
let badge = match (status2) {
    case "active"   => "green"
    case "pending"  => "yellow"
    case "inactive" => "red"
    case _          => "gray"
};
print sprintf("match expr: %s", badge);

// 43n) Complex real-world pattern matching
let processEvent = function(event) {
    return match (event) {
        case {type: "click", target: t}              => "clicked on " + t
        case {type: "keypress", key: k} if k == "Enter" => "submitted"
        case {type: "keypress", key: k}              => "pressed " + k
        case {type: t}                               => "event: " + t
        case _                                       => "unknown event"
    };
};
print processEvent({"type": "click", "target": "button"});
print processEvent({"type": "keypress", "key": "Enter"});
print processEvent({"type": "keypress", "key": "a"});
print processEvent({"type": "scroll"});

// Match with statements in case bodies
match (42) {
    case x if x > 0 => print sprintf("match statement: %d is positive", x)
    case _ => print "match statement: non-positive"
}

// -----------------------------------------------------------------------------
// 44) Async/await and concurrency
// -----------------------------------------------------------------------------
print "=== Async/await ===";

// 44a) Basic async function + await
let asyncDouble = async function(x) {
    return x * 2;
};
let futureVal = asyncDouble(21);
print sprintf("typeof future: %s", typeof futureVal);
let resolved = await futureVal;
print sprintf("await result: %d", resolved);

// 44b) Async arrow function
let asyncSquare = async (x) => x * x;
let sq = await asyncSquare(7);
print sprintf("async arrow: %d", sq);

// 44c) await on non-future passes through
let passthrough = await 42;
print sprintf("await non-future: %d", passthrough);

// 44d) await_all — concurrent execution of multiple futures
let slowAdd = async function(a, b) {
    return a + b;
};
let futures = [slowAdd(1, 2), slowAdd(3, 4), slowAdd(5, 6)];
let results = await_all(futures);
print sprintf("await_all: %v", results);

// 44e) await_race — first to complete wins
let raceA = async function() { return "A wins"; };
let raceB = async function() { return "B wins"; };
let winner = await_race([raceA(), raceB()]);
print sprintf("await_race: %s", winner);

// 44f) go_async — fire-and-forget (runs in background)
go_async(function() {
    // This runs concurrently; output may interleave
    let _ = 1 + 1;
});
print "go_async: fired";

// 44g) sleep builtin
print "sleep: before";
sleep(10); // 10ms — just to verify it works without blocking too long
print "sleep: after";

// 44h) Async error handling with try/catch
let asyncFail = async function() {
    throw "async boom";
};
let asyncCaught = try {
    await asyncFail();
} catch (e) {
    "caught async: " + e;
};
print sprintf("async error: %s", asyncCaught);

// -----------------------------------------------------------------------------
// 45) Structured errors (Error object + typed catch)
// -----------------------------------------------------------------------------
print "=== Structured errors ===";
let errObj = Error("Invalid input", {"code": "E_INPUT"});
print errObj;
let errCaught = try {
    throw Error("Bad payload", {"code": "E_PAYLOAD"});
} catch (e: Error) {
    "message=" + e.message + " code=" + e.code;
};
print errCaught;

// -----------------------------------------------------------------------------
// 46) Optional typing (typed let/function signatures)
// -----------------------------------------------------------------------------
print "=== Optional typing ===";
let typedX: int = 10;
let typedAdd = function(a: int, b: int): int {
    return a + b;
};
print typedX;
print typedAdd(20, 22);

// -----------------------------------------------------------------------------
// 47) Classes / OOP (lightweight)
// -----------------------------------------------------------------------------
print "=== Classes ===";
class User {
    constructor(name) {
        this.name = name;
    }

    greet() {
        return "Hello " + this.name;
    }
}

let u = new User("SPL");
print u.greet();

// -----------------------------------------------------------------------------
// 48) Interfaces (runtime metadata)
// -----------------------------------------------------------------------------
print "=== Interfaces ===";
interface Stringer {
    to_string(v: string): string;
}
print Stringer;

// -----------------------------------------------------------------------------
// 49) Generators + pipeline operator
// -----------------------------------------------------------------------------
print "=== Generator + Pipeline ===";
let gen = generator(function() {
    return [1, 2, 3, 4, 5];
});
print gen;

let stageMap = function(arr) { return arr.map(x => x * 2); };
let stageFilter = function(arr) { return arr.filter(x => x > 5); };
let stageReduce = function(arr) { return arr.reduce((a, b) => a + b, 0); };
let pipelineResult = [1, 2, 3, 4, 5] |> stageMap |> stageFilter |> stageReduce;
print pipelineResult;

// -----------------------------------------------------------------------------
// 50) Channels + go-style message passing builtin
// -----------------------------------------------------------------------------
print "=== Channels ===";
let ch = channel();
let producer = go(function() {
    send(ch, 42);
    return "sent";
});
print recv(ch);
print await producer;

// -----------------------------------------------------------------------------
// 51) Runtime permissions
// -----------------------------------------------------------------------------
print "=== Permissions ===";
permissions({"strict": true});
let deniedExec = try {
    exec("date", 1000);
} catch (e) {
    e;
};
print deniedExec;
permissions({"strict": false});

// -----------------------------------------------------------------------------
// 52) Observability hooks
// -----------------------------------------------------------------------------
print "=== Observability ===";
trace("showcase.start", {"section": "observability"});
metric("showcase_runs", 1);
metric("items_processed", 5);
print "trace/metric emitted";

// -----------------------------------------------------------------------------
// 53) Immutable data structures
// -----------------------------------------------------------------------------
print "=== Immutable ===";
let frozen = immutable({"a": 1});
let immResult = try {
    frozen.a = 2;
    "unexpected";
} catch (e) {
    e;
};
print immResult;

// -----------------------------------------------------------------------------
// 54) CLI args support
// -----------------------------------------------------------------------------
print "=== CLI args ===";
print ARGS;

print "=== Ownership model ===";
let ownedData = move([1, 2, 3]);
print ownedData;

// -----------------------------------------------------------------------------
// 55) Module init hooks + test blocks
// -----------------------------------------------------------------------------

type Result = Ok(value) | Err(error);
let resAdt = Ok(42);
print match (resAdt) {
    case Ok(v) => v
    case Err(e) => e
};

init {
    let init_marker = "module init executed";
    print init_marker;
}

test "typed add works" {
    assert_eq(typedAdd(2, 3), 5, "typed function in test block");
}

print "=== Showcase Complete ===";
