print [1, 2, 3].some(function(x) { return x > 2; });
print [1, 2, 3, 4, 5].reduce(function(acc, x) { return acc + x; }, 0);
print ["SPL", "is", "fun"].join(" ");

// -----------------------------------------------------------------------------
