let sv = 1;
sv <<= 8;
print sprintf("<<= : %d", sv);
sv >>= 4;
print sprintf(">>= : %d", sv);
let pv = 2;
pv **= 10;
print sprintf("**= : %d", pv);

// -----------------------------------------------------------------------------
// 32) Logical assignment operators
// -----------------------------------------------------------------------------
print "=== Logical assignment ===";
let la = null;
la &&= "ignored";
print sprintf("null &&= : %v", la);
let lb = "hello";
lb &&= "world";
print sprintf("truthy &&= : %s", lb);
let lc = null;
lc ||= "fallback";
print sprintf("null ||= : %s", lc);
let ld = "keep";
ld ||= "ignored";
print sprintf("truthy ||= : %s", ld);

