// -----------------------------------------------------------------------------
// 22) Extended array methods
// -----------------------------------------------------------------------------
print "=== Extended array methods ===";
let data = [3, 1, 4, 1, 5, 9, 2, 6];
print sprintf("length: %d", data.length);
