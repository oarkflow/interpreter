// -----------------------------------------------------------------------------
// 25) Null coalescing (?? and ??=)
// -----------------------------------------------------------------------------
print "=== Null coalescing ===";
let maybeNull = null;
print maybeNull ?? "fallback";
let definite = "exists";
print definite ?? "ignored";
let nc = null;
nc ??= "assigned";
print nc;
let nc2 = "keep";
nc2 ??= "ignored";
print nc2;

// -----------------------------------------------------------------------------
