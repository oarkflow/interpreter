// -----------------------------------------------------------------------------
// 31) Compound bitwise/power assignments
// -----------------------------------------------------------------------------
print "=== Compound bitwise/power assignments ===";
let bv = 0xFF;
bv &= 0x0F;
print sprintf("&= : %d", bv);
bv |= 0xF0;
print sprintf("|= : %d", bv);
bv ^= 0x0F;
