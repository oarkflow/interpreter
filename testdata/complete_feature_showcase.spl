// -----------------------------------------------------------------------------
// 27) Arrow functions
// -----------------------------------------------------------------------------
print "=== Arrow functions ===";
let double = (x) => x * 2;
print double(5);
let add_arrow = (a, b) => a + b;
print add_arrow(3, 4);
let hello_arrow = () => "hello from arrow";
print hello_arrow();
let square = x => x * x;
print square(9);
let block_arrow = (x) => { let r = x * 10; return r + 1; };
print block_arrow(3);
print [1, 2, 3].map((x) => x * 100);
print [1, 2, 3, 4, 5].filter(x => x > 3);

// -----------------------------------------------------------------------------
// 28) Destructuring (object and array)
