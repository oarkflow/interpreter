print "=== Math builtins ===";
let pi_val = PI();
let e_val = E();
print sprintf("PI() = %.5f", pi_val);
print sprintf("E() = %.5f", e_val);
print sprintf("sin(0) = %.1f", sin(0));
print sprintf("cos(0) = %.1f", cos(0));
print sprintf("log(E()) = %.1f", log(e_val));
print sprintf("sqrt(144) via 144**0.5 = %.1f", 144 ** 0.5);
print sprintf("is_nan(NAN()) = %t", is_nan(NAN()));

