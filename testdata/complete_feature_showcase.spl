print sprintf("name=%s role=%s", dName, dRole);

let {host: dHost, port: dPort = 8080} = {"host": "localhost"};
print sprintf("host=%s port=%d", dHost, dPort);

let {a: dA, ...dRest} = {"a": 1, "b": 2, "c": 3};
print sprintf("a=%d rest=%v", dA, dRest);

let [dFirst, dSecond, dThird] = [10, 20, 30];
print sprintf("first=%d second=%d third=%d", dFirst, dSecond, dThird);

let [dHead, ...dTail] = [1, 2, 3, 4, 5];
