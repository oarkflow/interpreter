// Complete SPL feature showcase.
// Run: go run ./cmd/interpreter testdata/complete_feature_showcase.spl

print "=== SPL Complete Feature Showcase ===";

// -----------------------------------------------------------------------------
// 1) Module system (default import, alias import, selective import, wildcard,
//    package-style bare imports resolved via testdata/spl.mod)
// -----------------------------------------------------------------------------
import "testdata/modules/lib/math.spl" as libmath;
import "testdata/modules/math.spl";
import {base, increment, label} from "testdata/modules/math.spl";
import * as mathns from "testdata/modules/math.spl";
import "showpkg/math.spl" as pkgmath;

print "Module alias answer (libmath.answer):";
print libmath.answer;
print "Selective imports:";
print base;
print increment;
print label;
print "Wildcard namespace mathns.base + mathns.increment:";
print mathns.base + mathns.increment;
print "Package import answer (pkgmath.answer):";
print pkgmath.answer;
print "Package import label:";
print pkgmath.label;

// -----------------------------------------------------------------------------
// 2) Variables, const, functions, closures, recursion
// -----------------------------------------------------------------------------
const MY_PI = 3.14159;
let radius = 3;
let area = MY_PI * radius * radius;
print "Circle area:";
print area;

let makeAdder = function(x) {
    return function(y) { x + y; };
};
let add10 = makeAdder(10);
print "Closure add10(5):";
print add10(5);

let fib = function(n) {
    if (n <= 1) { return n; }
    return fib(n - 1) + fib(n - 2);
};
print "fib(10):";
print fib(10);

// -----------------------------------------------------------------------------
// 3) Control flow (if/else, while, for, break, continue)
// -----------------------------------------------------------------------------
let sum = 0;
for (let i = 0; i < 10; i = i + 1) {
    if (i % 2 == 0) { continue; }
    sum = sum + i;
    if (sum > 20) { break; }
}
print "Control flow sum:";
print sum;

let counter = 0;
while (counter < 3) {
    print "while counter:";
    print counter;
    counter = counter + 1;
}

// -----------------------------------------------------------------------------
// 4) Arrays, hashes, methods
// -----------------------------------------------------------------------------
let nums = [1, 2, 3, 4, 5, 6];
let doubled = nums.map(function(x) { x * 2; });
let evens = nums.filter(function(x) { x % 2 == 0; });
let firstGt4 = nums.find(function(x) { x > 4; });
print "doubled:";
print doubled;
print "evens:";
print evens;
print "first > 4:";
print firstGt4;

let user = {
    "name": "SPL",
    "role": "demo",
    "meta": {"version": 1}
};
print "Dot access user.name:";
print user.name;
print "Hash keys length:";
print len(keys(user));

// -----------------------------------------------------------------------------
// 5) String, parse, json, encode/decode
// -----------------------------------------------------------------------------
let raw = "  hello,World  ";
let clean = trim(raw).replace(",", " ").title();
print "Clean title:";
print clean;

print "sprintf/printf/interpolate:";
let line = sprintf("name=%s count=%d ok=%t type=%T val=%v", "spl", 7, true, clean, {"k": 1});
print line;
printf("formatted user: %s (%d)\n", "alice", 30);
print interpolate("Hello {name}, items={count}", {"name": "SPL", "count": 3});
print interpolate("positional {0} + {1} = {2}", null, 20, 22, 42);

let piText = to_string(MY_PI);
let piFloat = parse_float(piText);
print "Parsed PI type:";
print type(piFloat);

let payload = {"name": "spl", "ok": true, "count": 3};
let jsonText = json_encode(payload);
let decoded = json_decode(jsonText);
print "JSON roundtrip name:";
print decoded.name;

let b64 = base64_encode("hello");
print "base64 roundtrip:";
print base64_decode(b64);

// -----------------------------------------------------------------------------
// 6) Crypto and time
// -----------------------------------------------------------------------------
print "sha256(abc):";
print hash("sha256", "abc");
print "hmac(sha256):";
print hmac("sha256", "demo-key", "payload");

let token = api_key("sk", 16);
print "api key prefix check:";
print starts_with(token, "sk_");

let ph = password_hash("s3cr3t");
print "password_verify:";
print password_verify("s3cr3t", ph);

let uid = uuid(4);
print "uuid length:";
print len(uid);
print "uuid v7 sample (default):";
print uuid();

let secret = "0123456789abcdef";
let cipher = encrypt("aes_gcm", secret, "top-secret");
let plain = decrypt("aes_gcm", secret, cipher);
print "decrypt(encrypt(...)):";
print plain;

let epoch = iso_to_unix("2020-01-01T00:00:00Z");
print "epoch:";
print epoch;
print "format_time(epoch):";
print format_time(epoch, "YYYY-MM-DD HH:mm:ss");
print "timezone conversion:";
print format_time_tz(epoch, "YYYY-MM-DD HH:mm", "America/New_York");
print "month arithmetic:";
print add_months(epoch, 1);

// -----------------------------------------------------------------------------
// 6.1) Hash and collection utility builtins
// -----------------------------------------------------------------------------
let profile = {"name": "Ada", "city": null};
print "has_key(profile, name):";
print has_key(profile, "name");
print "get(profile, city, fallback):";
print get(profile, "city", "Kathmandu");
print "merge hashes:";
print merge(profile, {"role": "engineer"});
print "delete_key hash:";
print delete_key(profile, "city");

print "collection numeric helpers:";
print clamp(19, 0, 10);
print round(3.6);
print floor(3.6);
print ceil(3.1);
print random_range(10, 20);
print coalesce(null, null, "fallback");
print coalesce(null, "default value");

// -----------------------------------------------------------------------------
// 7) File operations (safe path inside project)
// -----------------------------------------------------------------------------
let tmp = "testdata/demo_temp_showcase.txt";
write_file(tmp, "temporary content");
if (file_exists(tmp)) {
    print "file content:";
    print read_file(tmp);
    remove_file(tmp);
}

// -----------------------------------------------------------------------------
// 7.1) Database (SQLite in-memory, positional params, named params, tx)
// -----------------------------------------------------------------------------
let db, dberr = db_connect("sqlite", ":memory:");
if (dberr == null) {
    let createResult, cErr = db_exec(db, "CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, age INTEGER)");
    if (cErr == null) {
        let insertResult1, iErr1 = db_exec(db, "INSERT INTO users (name, age) VALUES (?, ?)", ["Alice", 30]);
        let insertResult2, iErr2 = db_exec(db, "INSERT INTO users (name, age) VALUES (:name, :age)", {"name": "Bob", "age": 22});
        if (iErr1 == null && iErr2 == null) {
            let tx, txErr = db_begin(db);
            if (txErr == null) {
                let rollbackInsert, rollbackInsertErr = db_exec(tx, "INSERT INTO users (name, age) VALUES (:name, :age)", {"name": "Rollback User", "age": 99});
                if (rollbackInsertErr == null) {
                    let rolledBack, rollbackErr = db_rollback(tx);
                    if (rollbackErr == null) {
                        print "db_rollback:";
                        print rolledBack;
                    }
                }
            }

            let countAfterRollback, countAfterRollbackErr = db_query(db, "SELECT COUNT(*) AS total FROM users", null, "array");
            if (countAfterRollbackErr == null) {
                print "db count after rollback:";
                print countAfterRollback;
            }

            let tx2, txErr2 = db_begin(db);
            if (txErr2 == null) {
                let commitInsert, commitInsertErr = db_exec(tx2, "INSERT INTO users (name, age) VALUES (:name, :age)", {"name": "Committed User", "age": 41});
                if (commitInsertErr == null) {
                    let committed, commitErr = db_commit(tx2);
                    if (commitErr == null) {
                        print "db_commit:";
                        print committed;
                    }
                }
            }

            let rows, qErr = db_query(db, "SELECT name, age FROM users ORDER BY age DESC", null, "array");
            if (qErr == null) {
                print "db_query rows after commit:";
                print rows;
            }
            let tables, tErr = db_tables(db);
            if (tErr == null) {
                print "db_tables:";
                print tables;
            }
        }
    }
    let closeOk, closeErr = db_close(db);
    if (closeErr != null) {
        print closeErr;
    }
} else {
    print dberr;
}

// -----------------------------------------------------------------------------
// 7.2) Command execution (whitelisted)
// -----------------------------------------------------------------------------
print "exec(date):";
print exec("date", 1000);

// -----------------------------------------------------------------------------
// 8) Error handling: try/catch/throw
// -----------------------------------------------------------------------------
let caught1 = try {
    throw "manual error";
} catch (e) {
    "expected caught: " + e;
};
print caught1;

let caught2 = try {
    unknown_identifier;
} catch (e) {
    "expected runtime: " + e;
};
print caught2;

// -----------------------------------------------------------------------------
// 9) Builtin introspection + SPL-native assertions/test summary
// -----------------------------------------------------------------------------
print "help(assert_eq):";
print help("assert_eq");

assert_true(libmath.answer == 42, "module value check");
assert_eq(mathns.base + mathns.increment, 42, "namespace check");
assert_true(contains(help(), "run_tests"), "help list includes run_tests");

print "test_summary:";
print test_summary();

print "run_tests on pass_assertions.spl:";
print run_tests("testdata/tests/pass_assertions.spl");

// -----------------------------------------------------------------------------
// 10) Integrations showcase (examples only)
// -----------------------------------------------------------------------------
// This block is intentionally disabled so the main showcase stays runnable
// without external services. Set to true when you want to test integrations.
if (false) {
    // HTTP
    let hres, herr = http_get("https://httpbin.org/get", {"Accept": "application/json"}, 5000);
    if (herr == null) {
        print hres.status_code;
    } else {
        print herr;
    }

    // Optional webhook example (disabled by default)
    if (false) {
        let wres, werr = webhook(
            "https://example.com/webhook",
            {"event": "build_complete", "ok": true, "time": now_iso()},
            {"X-Token": "demo-token"},
            3000
        );
        if (werr != null) { print werr; }
    }

    // SMTP
    let mailOk, mailErr = smtp_send({
        "host": "localhost",
        "port": 1025,
        "from": "noreply@localhost",
        "to": ["alice@localhost", "bob@localhost"],
        "subject": "SPL Integration Demo",
        "body": "Hello from SPL"
    });
    if (mailErr != null) { print mailErr; }

    // FTP/SFTP examples (disabled by default unless endpoints are available)
    if (false) {
        let ftpCfg = {
            "host": "ftp.example.com",
            "port": 21,
            "username": "ftp-user",
            "password": "ftp-pass",
            "timeout_ms": 5000
        };
        let files, listErr = ftp_list(ftpCfg, "/incoming");
        if (listErr == null) {
            print files;
            let fgetOk, fgetErr = ftp_get(ftpCfg, "/incoming/report.csv", "testdata/report.csv");
            if (fgetErr != null) { print fgetErr; }
            let fputOk, fputErr = ftp_put(ftpCfg, "testdata/report.csv", "/outgoing/report.csv");
            if (fputErr != null) { print fputErr; }
        } else {
            print listErr;
        }

        let sftpCfg = {
            "host": "sftp.example.com",
            "port": 22,
            "username": "sftp-user",
            "password": "sftp-pass",
            "timeout_ms": 5000
        };
        let sfiles, slistErr = sftp_list(sftpCfg, "/data");
        if (slistErr == null) {
            print sfiles;
            let sgetOk, sgetErr = sftp_get(sftpCfg, "/data/input.json", "testdata/input.json");
            if (sgetErr != null) { print sgetErr; }
            let sputOk, sputErr = sftp_put(sftpCfg, "testdata/input.json", "/data/output.json");
            if (sputErr != null) { print sputErr; }
        } else {
            print slistErr;
        }
    }
}

// -----------------------------------------------------------------------------
// 11) For-in loops (arrays, hashes, strings)
// -----------------------------------------------------------------------------
print "=== For-in loops ===";
let colors = ["red", "green", "blue"];
for (c in colors) { print c; }
for (i, c in colors) { print sprintf("%d: %s", i, c); }

let config = {"host": "localhost", "port": 8080};
for (k, v in config) { print sprintf("%s = %v", k, v); }

for (ch in "SPL") { print ch; }

// -----------------------------------------------------------------------------
// 12) Postfix increment / decrement
// -----------------------------------------------------------------------------
print "=== Postfix ++/-- ===";
let n = 10;
let prev = n++;
print sprintf("prev=%d, now=%d", prev, n);
n--;
print sprintf("after--: %d", n);

// -----------------------------------------------------------------------------
// 13) Ternary operator
// -----------------------------------------------------------------------------
print "=== Ternary operator ===";
let logged_in = true;
let greeting = logged_in ? "Welcome back!" : "Please log in";
print greeting;
print (radius > 5 ? "big" : "small");

// -----------------------------------------------------------------------------
// 14) Switch / case / default
// -----------------------------------------------------------------------------
print "=== Switch statement ===";
let lang = "spl";
switch (lang) {
  case "go":
    print "Go lang";
  case "spl":
    print "SPL lang";
  case "js", "ts":
    print "JavaScript family";
  default:
    print "unknown lang";
}

// -----------------------------------------------------------------------------
// 15) Optional chaining (?.)
// -----------------------------------------------------------------------------
print "=== Optional chaining ===";
let person = {"name": "Alice", "address": {"city": "NYC"}};
print person?.name;
print person?.address?.city;
let nobody = null;
print nobody?.name;
print person?.phone?.number;

// -----------------------------------------------------------------------------
// 16) Do-while loops
// -----------------------------------------------------------------------------
print "=== Do-while ===";
let countdown = 3;
do {
  print sprintf("countdown: %d", countdown);
  countdown--;
} while (countdown > 0);

// -----------------------------------------------------------------------------
// 17) Default parameters
// -----------------------------------------------------------------------------
print "=== Default parameters ===";
let greetUser = function(name, greeting = "Hello", punct = "!") {
  return sprintf("%s, %s%s", greeting, name, punct);
};
print greetUser("World");
print greetUser("World", "Hi");
print greetUser("World", "Hey", ".");

// -----------------------------------------------------------------------------
// 18) Rest parameters and spread operator
// -----------------------------------------------------------------------------
print "=== Rest/Spread ===";
let sumAll = function(...nums) {
  let total = 0;
  for (n in nums) { total = total + n; }
  return total;
};
print sumAll(1, 2, 3, 4, 5);

let first3 = [1, 2, 3];
let expanded = [0, ...first3, 4, 5];
print expanded;

// -----------------------------------------------------------------------------
