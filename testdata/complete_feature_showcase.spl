// -----------------------------------------------------------------------------
// 37) Finally block in try/catch
// -----------------------------------------------------------------------------
print "=== Finally block ===";
let finallyRan = false;
let tryResult = try {
    42;
} catch (e) {
    "caught";
} finally {
    finallyRan = true;
};
print sprintf("result=%v, finallyRan=%t", tryResult, finallyRan);

let finallyRan2 = false;
let catchResult = try {
    throw "oops";
} catch (e) {
    "caught: " + e;
} finally {
    finallyRan2 = true;
};
print sprintf("catch=%s, finallyRan=%t", catchResult, finallyRan2);

