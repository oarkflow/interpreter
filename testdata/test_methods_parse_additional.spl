let ok = true;

// String method style
if ("apple".upper() != "APPLE") { ok = false; }
if ("apple".toUpperCase() != "APPLE") { ok = false; }
if ("apple".includes("pp") != true) { ok = false; }
if ("  hello  ".trim() != "hello") { ok = false; }
if ("hello-world".replace("-", "_") != "hello_world") { ok = false; }

// Number method style
if ((-5).abs() != 5) { ok = false; }
if ((10).pow(2) != 100) { ok = false; }
if ((11).is_odd() != true) { ok = false; }
if ((10).is_even() != true) { ok = false; }
if ((10).to_float().to_int() != 10) { ok = false; }

// Integer timestamp as time object methods
if ((0).to_iso() != "1970-01-01T00:00:00Z") { ok = false; }
if ((0).format("YYYY-MM-DD") != "1970-01-01") { ok = false; }
if ((0).add(1, "day") != 86400) { ok = false; }
if ((86400).sub(1, "day") != 0) { ok = false; }
if ((86400).diff(0, "day") != 1) { ok = false; }

// Parse / conversion builtins
if (parse_int("42") != 42) { ok = false; }
if (to_int(parse_float("3.9")) != 3) { ok = false; }
if (parse_bool("yes") != true) { ok = false; }
if (parse_string(123) != "123") { ok = false; }
if (parse_type("12", "int") != 12) { ok = false; }
if (type(parse_type("12.5", "float")) != "FLOAT") { ok = false; }
if (parse_type("1970-01-01T00:00:00Z", "time") != 0) { ok = false; }
if (parse_type("1970-01-01 00:00:00", "time", "YYYY-MM-DD HH:mm:ss") != 0) { ok = false; }

ok;
