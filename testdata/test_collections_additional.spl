let ok = true;

if (first([10, 20, 30]) != 10) { ok = false; }
if (last([10, 20, 30]) != 30) { ok = false; }
if (len(rest([10, 20, 30])) != 2) { ok = false; }

let rev = reverse([1, 2, 3]);
if (rev[0] != 3 || rev[2] != 1) { ok = false; }

let sliced = slice([1, 2, 3, 4], 1, 3);
if (len(sliced) != 2 || sliced[0] != 2 || sliced[1] != 3) { ok = false; }

if (sum([1, 2, 3, 4]) != 10) { ok = false; }
if (avg([1, 2, 3, 4]) != 2.5) { ok = false; }

let flat = flatten([1, [2, 3], 4]);
if (len(flat) != 4 || flat[1] != 2 || flat[2] != 3) { ok = false; }

let compacted = compact([1, null, 2, null, 3]);
if (len(compacted) != 3) { ok = false; }

let m1 = {"a": 1, "b": 2};
if (has_key(m1, "a") != true) { ok = false; }
if (get(m1, "x", 99) != 99) { ok = false; }
if (len(values(m1)) != 2) { ok = false; }

let m2 = {"c": 3};
let merged = merge(m1, m2);
if (get(merged, "c") != 3) { ok = false; }

let deleted = delete_key(merged, "b");
if (has_key(deleted, "b") != false) { ok = false; }

if (coalesce(null, null, "x") != "x") { ok = false; }
if (default(null, "fallback") != "fallback") { ok = false; }
if (default("value", "fallback") != "value") { ok = false; }

if (clamp(20, 0, 10) != 10) { ok = false; }
if (is_even(10) != true) { ok = false; }
if (is_odd(11) != true) { ok = false; }

let rr = random_range(5, 10);
if (rr < 5 || rr >= 10) { ok = false; }

ok;
