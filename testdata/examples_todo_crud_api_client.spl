// =============================================================================
// TODO CRUD API Client Calls
// Start server first: go run ./cmd/interpreter testdata/examples_todo_crud_api_server.spl
// Then run:          go run ./cmd/interpreter testdata/examples_todo_crud_api_client.spl
// =============================================================================

print "=== SPL TODO CRUD API Client ===";

let jsonHeaders = {"Content-Type": "application/json"};

print "\n--- Create TODOs ---";
let create1, createErr1 = http_post("http://127.0.0.1:3020/api/todos", {
    "title": "Ship hydration runtime",
    "priority": "high",
    "notes": "Verify playground reactive preview"
}, jsonHeaders, 3000);
if (createErr1 != null) { throw createErr1; }
print create1.status_code;
print create1.body;

let create2, createErr2 = http_post("http://127.0.0.1:3020/api/todos", {
    "title": "Add TODO CRUD docs",
    "priority": "medium",
    "notes": "Explain server and client examples"
}, jsonHeaders, 3000);
if (createErr2 != null) { throw createErr2; }
print create2.status_code;
print create2.body;

print "\n--- List TODOs ---";
let listRes, listErr = http_get("http://127.0.0.1:3020/api/todos", {"Accept": "application/json"}, 3000);
if (listErr != null) { throw listErr; }
print listRes.status_code;
print listRes.body;

print "\n--- Get TODO by id ---";
let getRes, getErr = http_get("http://127.0.0.1:3020/api/todos/1", {"Accept": "application/json"}, 3000);
if (getErr != null) { throw getErr; }
print getRes.status_code;
print getRes.body;

print "\n--- Update TODO ---";
let updateRes, updateErr = http_request("PUT", "http://127.0.0.1:3020/api/todos/1", {
    "id": 1,
    "title": "Ship hydration runtime",
    "completed": true,
    "priority": "high",
    "notes": "Reactive toggle working"
}, jsonHeaders, 3000);
if (updateErr != null) { throw updateErr; }
print updateRes.status_code;
print updateRes.body;

print "\n--- Delete TODO ---";
let deleteRes, deleteErr = http_request("DELETE", "http://127.0.0.1:3020/api/todos/2", null, {"Accept": "application/json"}, 3000);
if (deleteErr != null) { throw deleteErr; }
print deleteRes.status_code;
print deleteRes.body;

print "\n--- Final TODO List ---";
let finalRes, finalErr = http_get("http://127.0.0.1:3020/api/todos", {"Accept": "application/json"}, 3000);
if (finalErr != null) { throw finalErr; }
print finalRes.status_code;
print finalRes.body;

print "\n=== TODO CRUD API Client Complete ===";
