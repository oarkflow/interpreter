// -----------------------------------------------------------------------------
// 7) SSR + Hydration (Template Integration)
// -----------------------------------------------------------------------------

print "\n--- SSR + Hydration ---";

// In templates, signals can be used with data-spl-* attributes for hydration:
//
// Template (templates/reactive_page.html):
//   <html>
//   <body>
//     @signal count = 0
//     @signal name = "World"
//
//     <h1 data-spl-bind="name" data-spl-attr="textContent">Hello ${name}!</h1>
//     <p>Count: <span data-spl-bind="count">0</span></p>
//     <input data-spl-bind="name" data-spl-attr="value" value="${name}" />
//     <button onclick="SPL.signal('count').set(SPL.signal('count').get() + 1)">
//       Increment
//     </button>
//
//     @effect
//       <!-- Re-renders when count changes -->
//       <div class="status">
//         Count is now: ${count}
//       </div>
//     @end
//   </body>
//   </html>
//
// The SSR renderer:
// 1. Renders initial HTML server-side (SEO-friendly)
// 2. Adds data-spl-* attributes for client binding
// 3. Generates hydration <script> that creates client-side signals
// 4. Two-way binding: input changes update signal, signal changes update DOM

// Programmatic SSR usage (Go API):
//   ssr := template.NewSSRRenderer(engine, data)
//   ssr.AddSignal("count", 0)
//   ssr.AddSignal("name", "World")
//   html, err := ssr.RenderSSR(templateString)
//   // html includes the rendered page + hydration script

print "SSR hydration generates client-side JavaScript for:";
print "  - Signal initialization from server state";
print "  - Two-way data binding (input <-> signal)";
print "  - Auto-updating DOM elements on signal change";
print "  - Event handlers that modify signals";

print "\n=== Reactive System Examples Complete ===";
